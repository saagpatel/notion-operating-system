# Optional profile selection. Leave blank to use the default profile.
NOTION_PROFILE=

# Required for live Notion reads and writes
NOTION_TOKEN=secret_xxx

# Optional runtime overrides.
NOTION_LOG_DIR=./logs
NOTION_RETRY_MAX_ATTEMPTS=5
NOTION_HTTP_TIMEOUT_MS=90000

# Optional advanced override. Leave this unset unless you intentionally want to bypass the active profile.
# NOTION_DESTINATIONS_PATH=./config/destinations.json

# Optional provider tokens for external signal sync
GITHUB_TOKEN=
VERCEL_TOKEN=
GOOGLE_CALENDAR_TOKEN=

# Optional governance and webhook credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PEM=
GITHUB_APP_WEBHOOK_SECRET=
VERCEL_WEBHOOK_SECRET=
GITHUB_BREAK_GLASS_TOKEN=
VERCEL_BREAK_GLASS_TOKEN=
