{
  "version": 1,
  "strategy": {
    "primary": "direct_rest",
    "fallback": "manual_review",
    "notes": [
      "Keep external source mapping rows repo-owned and additive.",
      "Seed the first wave from the highest-priority projects only.",
      "Create Needs Mapping rows when identifiers are unknown instead of fabricating mappings."
    ]
  },
  "seedRules": {
    "targetQueues": [
      "Resume Now",
      "Worth Finishing",
      "Needs Decision"
    ],
    "includePacketPriorities": [
      "Now",
      "Standby"
    ],
    "limit": 15
  },
  "sourceTemplates": [
    {
      "provider": "GitHub",
      "sourceType": "Repo",
      "titleSuffix": "GitHub Repo",
      "defaultStatus": "Needs Mapping",
      "defaultEnvironment": "N/A",
      "defaultSyncStrategy": "Poll"
    },
    {
      "provider": "Vercel",
      "sourceType": "Deployment Project",
      "titleSuffix": "Deployment Project",
      "defaultStatus": "Needs Mapping",
      "defaultEnvironment": "Production",
      "defaultSyncStrategy": "Poll"
    }
  ],
  "manualSeeds": []
}
