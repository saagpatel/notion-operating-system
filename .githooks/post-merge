#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$repo_root" ]]; then
  exit 0
fi

bootstrap_script="$repo_root/scripts/bootstrap-worktree-runtime.sh"
if [[ -x "$bootstrap_script" ]]; then
  "$bootstrap_script" >/dev/null 2>&1 || true
fi
